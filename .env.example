# ==========================================
# Biblia.ao — Variáveis de Ambiente (exemplo)
# Copiar para .env e preencher com valores reais.
# NUNCA commitar o ficheiro .env com segredos reais.
# ==========================================

# --- Geral ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Base de Dados (PostgreSQL) ---
DATABASE_URL="postgresql://biblia:biblia_dev_password@localhost:5432/biblia_ao?schema=public"

# --- Autenticação / JWT ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Storage (Cloudflare R2 / S3 compatível / Azure Blob) ---
STORAGE_PROVIDER="r2"                 # r2 | s3 | azure-blob
STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
STORAGE_REGION="auto"
STORAGE_BUCKET="biblia-ao-resources"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_BASE_URL="https://cdn.biblia.ao"
# Usados apenas quando STORAGE_PROVIDER="azure-blob" (ver infra/azure/resources.bicep,
# output "storageAccountName"; a chave obtém-se em Storage Account > Access keys)
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""

# --- API.Bible (importação de texto bíblico) ---
# Obter chave em https://scripture.api.bible/
API_BIBLE_KEY=""
API_BIBLE_BASE_URL="https://api.scripture.api.bible/v1"
# ID da(s) versão(ões) a importar em português (ex: Almeida Revista e Atualizada)
API_BIBLE_VERSION_IDS="ARA,NVI"

# --- IA Bíblica (Pergunte à Bíblia — RAG) ---
AI_PROVIDER="openai"                  # openai | azure-openai
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- E-mail ---
EMAIL_PROVIDER="resend"               # resend | sendgrid
EMAIL_API_KEY=""
EMAIL_FROM="Biblia.ao <naoresponder@biblia.ao>"

# --- Notificações Push (FCM) ---
FCM_SERVER_KEY=""

# --- Mapas ---
GOOGLE_MAPS_API_KEY=""

# --- Analytics ---
ANALYTICS_PROVIDER="plausible"        # plausible | ga4
PLAUSIBLE_DOMAIN="biblia.ao"

# --- Segurança ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CORS_ORIGINS="http://localhost:3000"
