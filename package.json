{
  "name": "biblia-ao",
  "version": "0.1.0",
  "private": true,
  "description": "Biblia.ao — plataforma digital para leitura, estudo e divulgação da Bíblia em Angola e no mundo lusófono",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "prisma:generate": "npm run prisma:generate --workspace=apps/api",
    "prisma:migrate": "npm run prisma:migrate --workspace=apps/api",
    "prisma:seed": "npm run prisma:seed --workspace=apps/api",
    "bible:import": "npm run bible:import --workspace=apps/api",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
